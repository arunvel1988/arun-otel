local.file_match "docker_logs" {

  path_targets = [
    {
      __path__ = "/var/lib/docker/containers/*/*.log",
    },
  ]

}


loki.source.file "containers" {

  targets = local.file_match.docker_logs.targets

  forward_to = [
    loki.process.parse.receiver,
  ]

}



loki.process "parse" {


  stage.docker {}


  stage.json {

    expressions = {
      level   = "level",
      service = "service",
      message = "message",
    }

  }


  stage.labels {

    values = {
      level   = "",
      service = "",
    }

  }


  forward_to = [
    loki.write.default.receiver,
  ]

}



loki.write "default" {

  endpoint {

    url = "http://loki:3100/loki/api/v1/push"

  }

}
